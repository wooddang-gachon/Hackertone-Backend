			"name": "1. Auth",
			"item": [
				{
					"name": "회원가입",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"url": { "raw": "http://localhost:3000/signUp/user", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "signUp", "user" ] },
						"body": { "mode": "raw", "raw": "{\n  \"gachon_id\": \"testuser1\",\n  \"name\": \"홍길동\",\n  \"password\": \"password123\"\n}" }
					}
				},
				{
					"name": "로그인",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
